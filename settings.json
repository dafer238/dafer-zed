// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // Appearance and UI settings
  "cli_default_open_behavior": "new_window",
  "buffer_font_family": "CaskaydiaCove Nerd Font",
  "buffer_font_size": 20.0,
  "icon_theme": {
    "dark": "Material Icon Theme",
    "light": "Material Icon Theme",
    "mode": "system",
  },
  "relative_line_numbers": "disabled",
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "tab_bar": {
    "show": false,
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "errors",
  },
  "theme": {
    "dark": "Gruvbox Dark",
    "light": "Gruvbox Light",
    "mode": "system",
  },
  "title_bar": {
    "show_branch_status_icon": true,
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "ui_font_family": "CaskaydiaCove Nerd Font",
  "ui_font_size": 20.0,
  "show_whitespaces": "trailing",
  "preferred_line_length": 100,
  "vertical_scroll_margin": 5.0,

  // Behavior and Editing
  "autosave": "on_focus_change",
  "format_on_save": "on",
  "vim_mode": true,

  // Debugger configuration
  "debugger": {
    "timeout": 10000,
  },

  // Git integration
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },

  // Language-specific settings
  "languages": {
    "Python": {
      "language_servers": ["!basedpyright", "ruff", "ty"],
    },
    "LaTeX": { "language_servers": ["texlab", "vale"], "format_on_save": "off" },
  },

  // LSP
  "lsp": {
    "texlab": {
      "settings": {
        "texlab": {
          "build": {
            "executable": "latexmk",
            "args": ["-interaction=nonstopmode", "-synctex=1", "%f"],
            "onSave": true,
            "forwardSearchAfter": true,
          },
          "forwardSearch": {
            "executable": "sioyek",
            "args": [
              "--reuse-window",
              "--forward-search-file",
              "%f",
              "--forward-search-line",
              "%l",
              "%p",
            ],
          },
          "chktex": {
            "onOpenAndSave": true,
            "onEdit": false,
          },
        },
      },
    },
  },

  // Project and file management
  "file_finder": {
    "modal_max_width": "large",
  },
  "file_scan_exclusions": ["**/__pycache__", "**/.vscode", "**/.git"],
  "project_panel": {
    "dock": "right",
    "entry_spacing": "standard",
    "git_status_indicator": true,
    "folder_icons" : false,
  },

  // Terminal settings
  "terminal": {
    "copy_on_select": true,
    "font_size": 16.0,
    "working_directory": "current_project_directory",
  },

  // Diagnostics and linting
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },

  // AI and Agent configuration
  "disable_ai": false,
  "agent": {
    "dock": "right",
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "model": "claude-sonnet-4-6",
      "provider": "zed.dev",
    },
    "default_profile": "ask",
    "notify_when_agent_waiting": "all_screens",
    "play_sound_when_agent_done": "always",
  },
  "show_edit_predictions": false,
}
